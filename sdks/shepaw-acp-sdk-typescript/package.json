{
  "name": "shepaw-acp-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building Shepaw ACP agents (WebSocket JSON-RPC 2.0). Wire-compatible with the Python shepaw_acp_sdk.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules/.cache",
    "example:echo": "tsx examples/echo-agent.ts"
  },
  "keywords": [
    "shepaw",
    "acp",
    "agent-client-protocol",
    "agent",
    "websocket",
    "json-rpc"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "debug": "^4.4.0",
    "noise-protocol": "^3.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
