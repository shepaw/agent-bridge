{
  "name": "shepaw-agent-hub",
  "version": "0.1.0",
  "description": "Supervisor CLI for running multiple Shepaw ACP agents on one host — each project gets its own X25519 identity and authorized-peers list, managed through a single `shepaw-hub` command.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "shepaw-hub": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "shepaw",
    "agent",
    "hub",
    "supervisor",
    "multi-agent"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "cac": "^6.7.14",
    "qrcode-terminal": "^0.12.0",
    "rotating-file-stream": "^3.2.3",
    "shepaw-acp-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.20.0"
  }
}
