{
  "name": "shepaw-claude-code-gateway",
  "version": "0.1.0",
  "description": "Run Claude Code as a Shepaw ACP agent — control Claude Code from your phone via Shepaw.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": "./dist/cli.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "shepaw-claude-code": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "shepaw",
    "claude-code",
    "claude",
    "agent",
    "acp"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "cac": "^6.7.14",
    "debug": "^4.4.0",
    "qrcode-terminal": "^0.12.0",
    "shepaw-acp-sdk": "*"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
